# Copy this file to ".env.local" and fill in real values. Never commit secrets.
# Next.js loads .env.local automatically; server-only vars (no NEXT_PUBLIC_
# prefix) stay out of the browser bundle.

# --- LLM / embedding provider ---
# Pick a provider and add its key. Example (Anthropic):
# ANTHROPIC_API_KEY=

# Model + retrieval knobs your lib/config.ts can read:
# LLM_MODEL=
# EMBEDDING_MODEL=
# CHUNK_SIZE=
# CHUNK_OVERLAP=
# TOP_K=
